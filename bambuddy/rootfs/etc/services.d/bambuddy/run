#!/usr/bin/with-contenv bashio

TZ=$(bashio::config 'timezone')
LOG_LEVEL=$(bashio::config 'log_level')

export TZ="${TZ:-Europe/Rome}"
export LOG_LEVEL="${LOG_LEVEL:-info}"

if bashio::config.has_value 'bind_address'; then
    BIND_ADDRESS=$(bashio::config 'bind_address')
    export BIND_ADDRESS="${BIND_ADDRESS}"
    bashio::log.info "Binding to: ${BIND_ADDRESS}"
fi

mkdir -p /data/bambuddy_data /data/bambuddy_logs

if [ ! -L /app/data ]; then
    rm -rf /app/data
    ln -s /data/bambuddy_data /app/data
fi
if [ ! -L /app/logs ]; then
    rm -rf /app/logs
    ln -s /data/bambuddy_logs /app/logs
fi

# Fix finish permissions at runtime
chmod +x /etc/services.d/bambuddy/finish 2>/dev/null || true

if bashio::config.has_value 'trusted_frame_origins'; then
    TRUSTED_FRAME_ORIGINS=$(bashio::config 'trusted_frame_origins')
    export TRUSTED_FRAME_ORIGINS="${TRUSTED_FRAME_ORIGINS}"
    bashio::log.info "Trusted frame origins: ${TRUSTED_FRAME_ORIGINS}"
fi

# Home Assistant integration.
# If ha_url/ha_token are not set, fall back to the Supervisor's internal
# Core API proxy (available because homeassistant_api: true in config.yaml
# makes the Supervisor inject SUPERVISOR_TOKEN into this container).
if bashio::config.has_value 'ha_url'; then
    HA_URL=$(bashio::config 'ha_url')
else
    HA_URL="http://supervisor/core"
fi
export HA_URL
bashio::log.info "Home Assistant URL: ${HA_URL}"

if bashio::config.has_value 'ha_token'; then
    HA_TOKEN=$(bashio::config 'ha_token')
else
    HA_TOKEN="${SUPERVISOR_TOKEN}"
fi
export HA_TOKEN

if bashio::config.has_value 'database_url'; then
    DATABASE_URL=$(bashio::config 'database_url')
    export DATABASE_URL="${DATABASE_URL}"
    bashio::log.info "Using external PostgreSQL database"
fi

# BAMBUDDY_EXTERNAL_ROOTS wants a colon-separated list of in-container paths.
# Map/media are mounted via config.yaml (share:rw, media:rw) so /share/... and
# /media/... are valid entries.
BAMBUDDY_EXTERNAL_ROOTS=$(bashio::jq "/data/options.json" '.bambuddy_external_roots // [] | join(":")')
if [ -n "${BAMBUDDY_EXTERNAL_ROOTS}" ]; then
    export BAMBUDDY_EXTERNAL_ROOTS
    bashio::log.info "External roots: ${BAMBUDDY_EXTERNAL_ROOTS}"
fi

if bashio::config.true 'use_system_trust_store'; then
    export USE_SYSTEM_TRUST_STORE="true"
    bashio::log.info "System trust store enabled"
fi

export PORT=8000
export PYTHONPATH=/app
export PYTHONUNBUFFERED=1

bashio::log.info "Starting BamBuddy on port ${PORT}..."

cd /app
exec python3 -m uvicorn backend.app.main:app \
    --host 0.0.0.0 \
    --port "${PORT}" \
    --loop asyncio